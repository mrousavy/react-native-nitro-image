{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": ["image", "blurhash"],
  "ios": {
    "iosModuleName": "NitroImageBlurhash"
  },
  "android": {
    "androidNamespace": ["image", "blurhash"],
    "androidCxxLibName": "NitroImageBlurhash"
  },
  "autolinking": {
    "BlurHashFactory": {
      "ios": {
        "language": "swift",
        "implementationClassName": "HybridBlurHashFactory"
      },
      "android": {
        "language": "kotlin",
        "implementationClassName": "HybridBlurHashFactory"
      }
    }
  },
  "ignorePaths": ["**/node_modules"]
}
